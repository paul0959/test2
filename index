    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            overflow-x: hidden; 
            background-color: #020617; /* slate-950 */
        }
        
        .math-text {
            font-family: 'Cambria Math', 'Times New Roman', Times, serif !important;
            letter-spacing: 0.02em;
        }

        mjx-container { outline: none; }
        
        /* Scrollbar personalizat */
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(99, 102, 241, 0.3); border-radius: 10px; }
        
        /* Utilitare pentru a ascunde elemente */
        .d-none { display: none !important; }
    </style>
</head>
<body class="min-h-screen p-0 sm:p-6 flex items-center justify-center selection:bg-indigo-500/30 text-slate-50">

    <!-- Main App Container - Mobile Look -->
    <div class="relative w-full h-[100dvh] sm:h-[850px] sm:max-w-[420px] bg-[#0f172a] sm:rounded-[40px] shadow-[0_30px_60px_rgba(0,0,0,0.5)] border-0 sm:border-[8px] sm:border-slate-800 overflow-hidden flex flex-col p-6 lg:p-8">
        
        <!-- Gradients de fundal -->
        <div class="absolute inset-0 pointer-events-none z-0 bg-slate-900">
           <div class="absolute top-[-10%] left-[-20%] w-[60%] h-[40%] bg-indigo-600/20 blur-[100px] rounded-full"></div>
           <div class="absolute bottom-[-10%] right-[-20%] w-[60%] h-[40%] bg-purple-600/20 blur-[100px] rounded-full"></div>
        </div>

        <!-- Antet -->
        <header class="relative z-10 text-center mb-4 shrink-0">
          <h1 class="text-[10px] font-bold tracking-widest uppercase text-indigo-400 mb-1">Solomon Haliță</h1>
          <p class="text-[10px] font-semibold text-slate-400 mb-2">Clasa a X-a B • Filologie</p>
          <div class="w-12 h-1 bg-gradient-to-r from-indigo-500 to-purple-500 mx-auto rounded-full"></div>
        </header>

        <!-- ECRAN 1: INTRO -->
        <div id="scr-intro" class="relative z-10 h-full w-full overflow-y-auto custom-scrollbar flex flex-col transition-opacity duration-300">
            <!-- Container interior setat cu min-h-full si pb-10 pt a nu taia butonul rosu de jos -->
            <div class="flex flex-col justify-center items-center w-full max-w-sm mx-auto min-h-full pb-10 pt-4">
                <div class="text-center mb-8">
                    <div class="w-24 h-24 bg-white/10 rounded-3xl flex items-center justify-center mx-auto mb-6 transform rotate-3 shadow-xl border border-white/20 backdrop-blur-md">
                        <i class="fa-solid fa-user text-indigo-400 text-4xl"></i>
                    </div>
                    <h2 class="text-3xl font-extrabold text-white tracking-tight">Să începem</h2>
                    <p class="text-slate-400 text-sm mt-2">Introdu numele complet și alege varianta.</p>
                </div>

                <div class="w-full space-y-5">
                    <div class="relative group">
                        <input 
                            type="text" 
                            id="user-name"
                            class="w-full px-6 py-4 rounded-2xl bg-white/10 border-2 border-slate-600/50 text-white placeholder-slate-400 focus:border-indigo-500 focus:bg-white/20 outline-none transition-all font-semibold backdrop-blur-sm"
                            placeholder="Nume și Prenume"
                        />
                    </div>

                    <div class="relative group">
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400">
                            <i class="fa-solid fa-chevron-down"></i>
                        </div>
                        <select
                            id="selected-variant"
                            class="w-full px-6 py-4 rounded-2xl bg-white/10 border-2 border-slate-600/50 text-white focus:border-indigo-500 focus:bg-white/20 outline-none transition-all font-semibold backdrop-blur-sm appearance-none cursor-pointer"
                        >
                            <option value="" disabled selected class="text-slate-800">Alege Varianta de Test...</option>
                            <option value="1" class="text-slate-800">Varianta 1</option>
                            <option value="2" class="text-slate-800">Varianta 2</option>
                            <option value="3" class="text-slate-800">Varianta 3</option>
                            <option value="4" class="text-slate-800">Varianta 4</option>
                        </select>
                    </div>

                    <div id="error-box" class="d-none bg-rose-500/10 border border-rose-500/50 text-rose-400 text-sm font-bold p-3 rounded-xl text-center">
                        <!-- Mesaj eroare -->
                    </div>

                    <!-- BUTON INCEPERE (ROSU) - Vizibil garantat acum datorita scroll-ului setat corect -->
                    <button 
                        onclick="startTest()"
                        class="w-full mt-4 p-5 rounded-2xl bg-red-600 text-white font-extrabold shadow-lg shadow-red-500/30 hover:bg-red-500 active:scale-95 transition-all flex justify-center items-center gap-2 text-lg border-2 border-red-500 hover:border-red-400"
                    >
                        Începe Evaluarea <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- ECRAN 2: QUIZ -->
        <div id="scr-quiz" class="d-none relative z-10 flex flex-col h-full transition-opacity duration-300">
            <!-- Header cu Dots -->
            <div class="flex justify-between items-center mb-6 shrink-0">
                <span id="quiz-variant-tag" class="text-[11px] font-black bg-slate-800 text-white px-3 py-1.5 rounded-lg border border-slate-700 shadow-sm">
                    VAR X
                </span>
                <div id="nav-dots" class="flex gap-1.5">
                    <!-- Dots generate dinamic -->
                </div>
            </div>

            <!-- Zona Întrebare -->
            <div class="bg-white rounded-[24px] p-6 shadow-xl border border-slate-200 mb-6 flex flex-col items-center justify-center min-h-[160px] relative overflow-hidden shrink-0">
                <div class="absolute top-0 w-full h-1 bg-gradient-to-r from-indigo-500 to-purple-500"></div>
                <p id="quiz-q-num" class="text-slate-400 text-sm font-bold w-full text-left mb-2 uppercase tracking-widest font-sans">Exercițiul X</p>
                <div id="quiz-q-text" class="text-slate-800 font-bold text-center w-full text-[19px] leading-relaxed math-text">
                    <!-- Întrebarea -->
                </div>
            </div>

            <!-- Zona Opțiuni -->
            <div id="quiz-options" class="space-y-3 flex-grow overflow-y-auto custom-scrollbar pr-1 pb-4">
                <!-- Opțiuni generate dinamic -->
            </div>

            <!-- Footer Navigation -->
            <div class="mt-4 grid grid-cols-2 gap-4 shrink-0 pb-2">
                <button 
                    id="btn-prev"
                    onclick="handlePrev()" 
                    class="flex justify-center items-center py-4 rounded-xl bg-slate-800 text-slate-300 font-bold text-sm hover:bg-slate-700 transition-all disabled:opacity-40 disabled:active:scale-100 active:scale-95 gap-2 font-sans"
                >
                    <i class="fa-solid fa-arrow-left"></i> Anterior
                </button>
                
                <button 
                    id="btn-next"
                    onclick="handleNext()" 
                    class="flex justify-center items-center py-4 rounded-xl bg-indigo-600 text-white font-bold text-sm shadow-lg shadow-indigo-500/30 hover:bg-indigo-500 transition-all active:scale-95 gap-2 font-sans"
                >
                    Următorul <i class="fa-solid fa-arrow-right"></i>
                </button>

                <button 
                    id="btn-finalize"
                    onclick="finalizeTest()"
                    class="d-none flex justify-center items-center py-4 rounded-xl font-bold text-sm shadow-lg transition-all gap-2 font-sans bg-slate-700 text-slate-500 cursor-not-allowed opacity-50"
                >
                    Finalizează Test <i class="fa-solid fa-check-circle"></i>
                </button>
            </div>
        </div>

        <!-- ECRAN 3: REZULTATE -->
        <div id="scr-results" class="d-none relative z-10 flex flex-col h-full transition-opacity duration-300 overflow-y-auto custom-scrollbar">
            <div class="flex-grow flex flex-col items-center justify-center py-6">
                
                <div class="w-40 h-40 shrink-0 rounded-full border-[10px] border-indigo-500 flex flex-col items-center justify-center shadow-[0_0_40px_rgba(99,102,241,0.3)] bg-slate-900 mb-6 relative">
                    <span class="text-xs uppercase font-extrabold text-indigo-400 tracking-widest absolute top-6">Nota</span>
                    <div id="res-score" class="text-6xl font-black text-white mt-4">10</div>
                </div>
                
                <div class="text-center w-full mb-8 shrink-0">
                    <h4 id="res-name" class="text-2xl font-extrabold text-white">Nume Elev</h4>
                    <p id="res-variant" class="text-emerald-400 font-medium mt-1">Evaluare finalizată • Varianta X</p>
                </div>

                <div class="w-full mb-6 shrink-0">
                    <button 
                        id="btn-export"
                        onclick="exportToJPG()"
                        class="w-full py-4 rounded-2xl font-extrabold text-white text-sm shadow-lg shadow-indigo-500/20 flex justify-center items-center gap-2 transition-all bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 active:scale-95 border border-indigo-500"
                    >
                        <i class="fa-solid fa-image"></i> <span>Exportă Rezultatul (JPG)</span>
                    </button>
                </div>

                <div class="w-full flex-grow flex flex-col shrink-0">
                    <button 
                        id="btn-toggle-barem"
                        onclick="toggleBarem()" 
                        class="w-full py-4 bg-emerald-500/10 text-emerald-400 rounded-2xl font-bold border border-emerald-500/30 text-sm flex justify-center items-center gap-2 transition-all hover:bg-emerald-500/20"
                    >
                        <i class="fa-solid fa-eye"></i> VIZUALIZEAZĂ BAREMUL
                    </button>
                    
                    <div id="barem-container" class="d-none mt-4 w-full flex-col space-y-3 pb-4">
                        <!-- Barem generat dinamic -->
                    </div>
                </div>

                <button 
                    onclick="restartApp()" 
                    class="mt-8 text-sm text-slate-400 font-bold uppercase tracking-wider hover:text-white transition-colors flex items-center gap-2 shrink-0"
                >
                    <i class="fa-solid fa-rotate-left"></i> Ieșire
                </button>
            </div>
        </div>

        <!-- OVERLAY SECURITATE -->
        <div id="security-overlay" class="d-none absolute inset-0 z-50 bg-slate-950/95 backdrop-blur-xl flex flex-col items-center justify-center p-8 text-center transition-opacity duration-300">
            <div class="w-24 h-24 bg-rose-500/20 rounded-full flex items-center justify-center mb-6 border border-rose-500/50">
                <i class="fa-solid fa-shield-halved text-rose-500 text-5xl"></i>
            </div>
            <h2 class="text-3xl font-extrabold text-white mb-3">Activitate Suspectă</h2>
            <p class="text-slate-400 text-lg mb-10 max-w-xs">
                Se pare că ai părăsit fereastra evaluării. Rămâi pe acest ecran pentru a evita anularea testului!
            </p>
            <button 
                onclick="dismissSecurity()" 
                class="w-full max-w-xs py-5 bg-white text-slate-900 font-extrabold rounded-2xl shadow-xl hover:scale-105 active:scale-95 transition-all"
            >
                REVINO LA TEST
            </button>
        </div>

    </div>

    <!-- TEMPLATE EXPORT ASCUNS (Rendat off-screen pentru html2canvas) -->
    <div id="export-template" style="display: none; position: absolute; left: -9999px; top: -9999px; width: 800px; background-color: #0f172a; padding: 60px; font-family: 'Plus Jakarta Sans', sans-serif;">
        <div style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); height: 12px; border-radius: 10px; margin-bottom: 40px;"></div>
        <div style="text-align: center;">
            <h1 style="color: #f8fafc; margin: 0; font-size: 36px; font-weight: 800; letter-spacing: -1px;">Liceul Teoretic Solomon Haliță</h1>
            <p style="font-size: 20px; color: #94a3b8; margin: 10px 0; font-weight: 600;">Evaluare Matematică - Profil Filologie</p>
            <div style="height: 2px; background: #334155; margin: 40px auto; width: 60%;"></div>
        </div>

        <div style="display: flex; justify-content: space-between; gap: 30px; margin-top: 40px;">
            <div style="flex: 1; background: #1e293b; padding: 40px; border-radius: 24px; border: 1px solid #334155;">
                <p style="color: #64748b; font-size: 14px; text-transform: uppercase; font-weight: 800; margin: 0 0 5px 0;">Elev</p>
                <p id="exp-name" style="color: #f8fafc; font-size: 28px; font-weight: 800; margin: 0 0 30px 0;">NUME</p>
                
                <p style="color: #64748b; font-size: 14px; text-transform: uppercase; font-weight: 800; margin: 0 0 5px 0;">Subiect</p>
                <p style="color: #cbd5e1; font-size: 20px; font-weight: 600; margin: 0 0 30px 0;">Puteri, Radicali, Logaritmi</p>
                
                <p style="color: #64748b; font-size: 14px; text-transform: uppercase; font-weight: 800; margin: 0 0 5px 0;">Varianta Extrasă</p>
                <p id="exp-variant" style="color: #818cf8; font-size: 24px; font-weight: 800; margin: 0;">Numărul X</p>
            </div>

            <div style="flex: 1; display: flex; flex-direction: column; gap: 20px;">
                <div style="background: #1e293b; padding: 40px; border-radius: 24px; border: 2px solid #4f46e5; text-align: center; flex: 1; display: flex; flex-direction: column; justify-content: center;">
                    <p style="color: #818cf8; font-size: 16px; text-transform: uppercase; font-weight: 800; margin: 0;">Nota Finală</p>
                    <h3 id="exp-score" style="margin: 10px 0; font-size: 110px; color: #f8fafc; font-weight: 900; line-height: 1;">10</h3>
                    <p style="color: #94a3b8; font-size: 14px; margin: 0;">+10 Puncte din Oficiu incluse</p>
                </div>
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; margin-top: 30px; background: #020617; padding: 25px 40px; border-radius: 20px; border: 1px solid #1e293b;">
            <div style="display: flex; align-items: center; gap: 10px; color: #cbd5e1; font-size: 18px; font-weight: 600;">
               <i class="fa-solid fa-calendar" style="color:#818cf8;"></i> Data: <span id="exp-date"></span> la <span id="exp-time"></span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px; color: #cbd5e1; font-size: 18px; font-weight: 600;">
               <i class="fa-solid fa-clock" style="color:#10b981;"></i> Durata test: <span id="exp-duration"></span>
            </div>
        </div>
        <div style="text-align: center; color: #475569; font-size: 14px; margin-top: 40px; font-weight: 600;">
            Certificat digital emis automat prin platforma de evaluare.
        </div>
    </div>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        const DATABASE = {
            1: [
                { q: "Calculaţi valoarea expresiei cu puteri: $125^{\\frac{1}{3}}\\cdot5^{2}$", opts: ["5", "25", "125", "625"], ans: 2, just: "$125^{1/3} = \\sqrt[3]{125} = 5$. Deci $5 \\cdot 5^2 = 5^3 = 125$." },
