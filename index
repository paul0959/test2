                { q: "Calculaţi: $\\frac{10^{5}\\cdot100^{2}}{1000^{2}}$", opts: ["10", "100", "1000", "10000"], ans: 2, just: "$100 = 10^2, 1000 = 10^3$. Avem $\\frac{10^5 \\cdot 10^4}{10^6} = \\frac{10^9}{10^6} = 10^3 = 1000$." },
                { q: "Efectuați calculul cu radicali: $\\sqrt{28}+\\sqrt{63}-\\sqrt{175}$", opts: ["0", "$\\sqrt{7}$", "$-\\sqrt{7}$", "$2\\sqrt{7}$"], ans: 0, just: "$\\sqrt{28}=2\\sqrt{7}$; $\\sqrt{63}=3\\sqrt{7}$; $\\sqrt{175}=5\\sqrt{7}$. Calcul: $2\\sqrt{7} + 3\\sqrt{7} - 5\\sqrt{7} = 0$." },
                { q: "Calculaţi valoarea expresiei: $\\sqrt[3]{-343}+\\sqrt[4]{81}$", opts: ["-10", "-4", "4", "10"], ans: 1, just: "$\\sqrt[3]{-343} = -7$. $\\sqrt[4]{81} = 3$. Rezultat: $-7 + 3 = -4$." },
                { q: "Domeniul maxim de existenţă pentru radicalul $\\sqrt{5x-20}$ este:", opts: ["$[4,\\infty)$", "$(4,\\infty)$", "$(-\\infty,4]$", "$\\mathbb{R}$"], ans: 0, just: "Condiție: $5x - 20 \\ge 0 \\implies 5x \\ge 20 \\implies x \\ge 4$. Domeniul: $[4, \\infty)$." },
                { q: "Domeniul maxim de existență pentru logaritmul $\\log_{7}(x^{2}-x-2)$ este:", opts: ["$(-\\infty,-1)\\cup(2,\\infty)$", "$(-1,2)$", "$[-1,2]$", "$\\mathbb{R}$"], ans: 0, just: "Ecuația $x^2-x-2=0$ are rădăcinile $x_1=-1, x_2=2$. Parabola este $>0$ în exterior: $(-\\infty, -1) \\cup (2, \\infty)$." },
                { q: "Utilizând proprietățile operațiilor cu logaritmi, calculați: $A=\\log_{5}100-\\log_{5}4$", opts: ["2", "5", "25", "10"], ans: 0, just: "$A = \\log_5(\\frac{100}{4}) = \\log_5 25 = 2$." },
                { q: "Calculați: $P=\\log_{5}2\\cdot \\log_{2}9\\cdot \\log_{3}25$", opts: ["2", "3", "4", "5"], ans: 2, just: "Transformăm: $\\log_5 2 \\cdot 2\\log_2 3 \\cdot 2\\log_3 5 = 4 \\cdot (\\log_5 2 \\cdot \\log_2 3 \\cdot \\log_3 5) = 4 \\cdot \\log_5 5 = 4$." },
                { q: "Calculaţi valoarea expresiei mixte: $E=7^{\\log_{7}20}+\\log_{\\sqrt{2}}(4)-100^{\\frac{1}{2}\\lg~16}$", opts: ["4", "6", "8", "10"], ans: 2, just: "$7^{\\log_7 20} = 20$. $\\log_{\\sqrt{2}}(4) = \\log_{2^{1/2}}(2^2) = \\frac{2}{1/2} = 4$. $100^{\\frac{1}{2}\\lg 16} = 10^{2 \\cdot \\frac{1}{2} \\lg 16} = 10^{\\lg 16} = 16$. Rezultat: $20 + 4 - 16 = 8$." }
            ],
            4: [
                { q: "Calculaţi valoarea expresiei cu puteri: $27^{\\frac{4}{3}}\\cdot3^{-3}$", opts: ["1", "3", "9", "27"], ans: 1, just: "$27^{4/3} = (3^3)^{4/3} = 3^4 = 81$. Deci $81 \\cdot 3^{-3} = 81 / 27 = 3$." },
                { q: "Calculaţi: $\\frac{5^{6}\\cdot25^{2}}{125^{3}}$", opts: ["1", "5", "25", "125"], ans: 1, just: "$25 = 5^2, 125 = 5^3$. $\\frac{5^6 \\cdot (5^2)^2}{(5^3)^3} = \\frac{5^6 \\cdot 5^4}{5^9} = \\frac{5^{10}}{5^9} = 5^1 = 5$." },
                { q: "Efectuaţi calculul cu radicali: $\\sqrt{108}-\\sqrt{75}+\\sqrt{27}$", opts: ["$\\sqrt{3}$", "$2\\sqrt{3}$", "$3\\sqrt{3}$", "$4\\sqrt{3}$"], ans: 3, just: "$\\sqrt{108}=6\\sqrt{3}$; $\\sqrt{75}=5\\sqrt{3}$; $\\sqrt{27}=3\\sqrt{3}$. Calcul: $6\\sqrt{3} - 5\\sqrt{3} + 3\\sqrt{3} = 4\\sqrt{3}$." },
                { q: "Calculaţi valoarea expresiei: $\\sqrt[3]{-512}+\\sqrt[4]{10000}$", opts: ["2", "-2", "18", "-18"], ans: 0, just: "$\\sqrt[3]{-512} = -8$. $\\sqrt[4]{10000} = 10$. Deci $-8 + 10 = 2$." },
                { q: "Domeniul maxim de existență pentru radicalul $\\sqrt{18-6x}$ este:", opts: ["$(-\\infty,3]$", "$[3,\\infty)$", "$(-\\infty,3)$", "$\\mathbb{R}$"], ans: 0, just: "Condiție: $18 - 6x \\ge 0 \\implies 18 \\ge 6x \\implies 3 \\ge x$. Deci intervalul este $(-\\infty, 3]$." },
                { q: "Domeniul maxim de existență pentru logaritmul $\\log_{2}(x^{2}-9)$ este:", opts: ["$(-\\infty,-3)\\cup(3,\\infty)$", "$(-3,3)$", "$[-3,3]$", "$\\mathbb{R}\\setminus\\{-3,3\\}$"], ans: 0, just: "Ecuația $x^2-9>0$ are rădăcinile $x=\\pm 3$. Valori pozitive în exteriorul rădăcinilor: $(-\\infty, -3) \\cup (3, \\infty)$." },
                { q: "Utilizând proprietățile operațiilor cu logaritmi, calculați: $A=\\log_{4}80-\\log_{4}5$", opts: ["2", "4", "16", "8"], ans: 0, just: "Folosind regula împărțirii: $A = \\log_4(\\frac{80}{5}) = \\log_4(16) = 2$." },
                { q: "Calculați: $P=\\log_{4}7\\cdot \\log_{7}81\\cdot \\log_{9}2$", opts: ["1", "2", "3", "4"], ans: 0, just: "Reducem bazele folosind schimbarea de bază: $\\frac{\\log 7}{\\log 4} \\cdot \\frac{\\log 81}{\\log 7} \\cdot \\frac{\\log 2}{\\log 9} = \\frac{\\log 81 \\cdot \\log 2}{\\log 4 \\cdot \\log 9} = \\frac{4\\log 3 \\cdot \\log 2}{2\\log 2 \\cdot 2\\log 3} = 1$." },
                { q: "Calculați valoarea expresiei mixte: $E=2^{\\log_{2}18}+\\log_{\\frac{1}{2}}(16)-10^{\\lg~14}$", opts: ["0", "1", "2", "4"], ans: 0, just: "$2^{\\log_2 18} = 18$. $\\log_{1/2} 16 = -4$. $10^{\\lg 14} = 14$. Calcul: $18 - 4 - 14 = 0$." }
            ]
        };

        // STARE APLICAȚIE
        let appState = 'intro'; // 'intro', 'quiz', 'results'
        let userName = '';
        let selectedVariant = '';
        let questions = [];
        let currentIndex = 0;
        let answers = Array(9).fill(null);
        let score = 1;
        let startTime = null;
        let testStats = { date: '', time: '', duration: '' };

        // DOM ELEMENTS
        const elUserName = document.getElementById('user-name');
        const elSelectedVariant = document.getElementById('selected-variant');
        const elErrorBox = document.getElementById('error-box');
        const scrIntro = document.getElementById('scr-intro');
        const scrQuiz = document.getElementById('scr-quiz');
        const scrResults = document.getElementById('scr-results');
        const securityOverlay = document.getElementById('security-overlay');

        // LISTENERS
        elUserName.addEventListener('input', (e) => {
            const cleanName = e.target.value.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            e.target.value = cleanName;
            userName = cleanName;
            elErrorBox.classList.add('d-none');
        });

        elSelectedVariant.addEventListener('change', (e) => {
            selectedVariant = e.target.value;
            elErrorBox.classList.add('d-none');
        });

        window.addEventListener('blur', () => {
            if (appState === 'quiz') {
                securityOverlay.classList.remove('d-none');
            }
        });

        function showError(msg) {
            elErrorBox.textContent = msg;
            elErrorBox.classList.remove('d-none');
        }

        function dismissSecurity() {
            securityOverlay.classList.add('d-none');
        }

        // FUNCTII CORE
        function startTest() {
            if (!userName.trim()) {
                showError("Introduceți numele complet!");
                return;
            }
            if (!selectedVariant) {
                showError("Vă rugăm să alegeți o variantă de test!");
                return;
            }

            const normalizedName = userName.trim().toLowerCase();
            
            // Verificare local storage
            let attempts = [];
            try {
                attempts = JSON.parse(localStorage.getItem('eval_math_attempts') || '[]');
            } catch(e) {}

            if (attempts.includes(normalizedName)) {
                showError("Ai susținut deja acest test! Nu se permit încercări multiple.");
                return;
            }

            questions = DATABASE[selectedVariant];
            answers = Array(9).fill(null);
            currentIndex = 0;
            score = 1;
            startTime = Date.now();
            
            switchScreen('quiz');
            renderQuiz();
        }

        function switchScreen(target) {
            appState = target;
            scrIntro.classList.add('d-none');
            scrQuiz.classList.add('d-none');
            scrResults.classList.add('d-none');

            if (target === 'intro') scrIntro.classList.remove('d-none');
            if (target === 'quiz') scrQuiz.classList.remove('d-none');
            if (target === 'results') scrResults.classList.remove('d-none');
        }

        function renderQuiz() {
            const q = questions[currentIndex];
            const isLast = currentIndex === 8;
            const alreadyAnswered = answers[currentIndex] !== null;

            // Update Header (Dots & Tag)
            document.getElementById('quiz-variant-tag').innerText = `VAR ${selectedVariant}`;
            const dotsContainer = document.getElementById('nav-dots');
            dotsContainer.innerHTML = '';
            for(let i=0; i<9; i++) {
                let dotClass = 'w-2.5 h-2.5 rounded-full transition-all duration-300 ';
                if (i === currentIndex) dotClass += 'scale-150 bg-indigo-500';
                else if (answers[i] !== null) dotClass += 'bg-emerald-500';
                else dotClass += 'bg-slate-700';
                
                dotsContainer.innerHTML += `<div class="${dotClass}"></div>`;
            }

            // Update Question
            document.getElementById('quiz-q-num').innerText = `Exercițiul ${currentIndex + 1}`;
            document.getElementById('quiz-q-text').innerHTML = q.q;

            // Update Options
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            
            q.opts.forEach((opt, idx) => {
                const isSelected = answers[currentIndex] === idx;
                let btnClass = "bg-white border-slate-200 text-slate-700 hover:border-indigo-300 active:scale-[0.98]";
                let iconClass = "bg-slate-100 text-slate-500";
                let rightIcon = "";

                if (alreadyAnswered) {
                    btnClass = btnClass.replace("hover:border-indigo-300 active:scale-[0.98]", "");
                    if (idx === q.ans) {
                        btnClass = "bg-emerald-500 border-emerald-600 text-white shadow-lg shadow-emerald-500/20";
                        iconClass = "bg-white/20 text-white";
                        rightIcon = '<i class="fa-solid fa-check-circle text-white ml-auto text-xl shrink-0"></i>';
                    } else if (isSelected) {
                        btnClass = "bg-rose-500 border-rose-600 text-white";
                        iconClass = "bg-white/20 text-white";
                        rightIcon = '<i class="fa-solid fa-xmark-circle text-white ml-auto text-xl shrink-0"></i>';
                    } else {
                        btnClass = "bg-white/50 border-slate-100 text-slate-400 opacity-60";
                    }
                }

                const btnHtml = `
                    <button 
                        onclick="selectOption(${idx})"
                        ${alreadyAnswered ? 'disabled' : ''}
                        class="w-full text-left p-4 rounded-2xl border-2 shadow-sm flex items-center gap-4 transition-all duration-300 ${btnClass}"
                    >
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center font-extrabold text-sm uppercase shrink-0 transition-colors font-sans ${iconClass}">
                            ${String.fromCharCode(97 + idx)}
                        </div>
                        <span class="font-bold text-[18px] math-text">${opt}</span>
                        ${rightIcon}
                    </button>
                `;
                optionsContainer.innerHTML += btnHtml;
            });

            // Update Navigation Buttons
            document.getElementById('btn-prev').disabled = currentIndex === 0;
            const btnNext = document.getElementById('btn-next');
            const btnFinalize = document.getElementById('btn-finalize');
            
            if (isLast) {
                btnNext.classList.add('d-none');
                btnFinalize.classList.remove('d-none');
                
                const allAnswered = !answers.includes(null);
                if (allAnswered) {
                    btnFinalize.className = "flex justify-center items-center py-4 rounded-xl font-bold text-sm shadow-lg transition-all gap-2 font-sans bg-emerald-600 hover:bg-emerald-500 text-white shadow-emerald-500/30 active:scale-95 border border-emerald-500";
                    btnFinalize.disabled = false;
                } else {
                    btnFinalize.className = "flex justify-center items-center py-4 rounded-xl font-bold text-sm shadow-lg transition-all gap-2 font-sans bg-slate-700 text-slate-500 cursor-not-allowed opacity-50";
                    btnFinalize.disabled = true;
                }
            } else {
                btnNext.classList.remove('d-none');
                btnFinalize.classList.add('d-none');
            }

            // MathJax re-render
            if (window.MathJax && window.MathJax.typesetPromise) {
                window.MathJax.typesetPromise([document.getElementById('scr-quiz')]);
            }
        }

        function selectOption(idx) {
            if (answers[currentIndex] !== null) return;
            answers[currentIndex] = idx;
            renderQuiz();
        }

        function handleNext() {
            if (currentIndex < 8) {
                currentIndex++;
                renderQuiz();
            }
        }

        function handlePrev() {
            if (currentIndex > 0) {
                currentIndex--;
                renderQuiz();
            }
        }

        function finalizeTest() {
            if (answers.includes(null)) return;

            const end = Date.now();
            const diffInSeconds = Math.floor((end - startTime) / 1000);
            const mins = Math.floor(diffInSeconds / 60);
            const secs = diffInSeconds % 60;
            testStats.duration = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;

            const now = new Date();
            testStats.date = now.toLocaleDateString('ro-RO');
            testStats.time = now.toLocaleTimeString('ro-RO', { hour: '2-digit', minute: '2-digit' });

            score = 1;
            answers.forEach((ans, idx) => {
                if (ans === questions[idx].ans) score += 1;
            });

            // Save Attempt
            const normalizedName = userName.trim().toLowerCase();
            try {
                let attempts = JSON.parse(localStorage.getItem('eval_math_attempts') || '[]');
                if (!attempts.includes(normalizedName)) {
                    attempts.push(normalizedName);
                    localStorage.setItem('eval_math_attempts', JSON.stringify(attempts));
                }
            } catch(e) {}

            renderResults();
        }

        function renderResults() {
            switchScreen('results');
            document.getElementById('res-score').innerText = score;
            document.getElementById('res-name').innerText = userName;
            document.getElementById('res-variant').innerText = `Evaluare finalizată • Varianta ${selectedVariant}`;

            // Populate Export template
            document.getElementById('exp-name').innerText = userName.toUpperCase() || 'N/A';
            document.getElementById('exp-variant').innerText = `Numărul ${selectedVariant}`;
            document.getElementById('exp-score').innerText = score;
            document.getElementById('exp-date').innerText = testStats.date;
            document.getElementById('exp-time').innerText = testStats.time;
            document.getElementById('exp-duration').innerText = testStats.duration;
        }

        function toggleBarem() {
            const container = document.getElementById('barem-container');
            const isHidden = container.classList.contains('d-none');
            const btn = document.getElementById('btn-toggle-barem');

            if (isHidden) {
                container.innerHTML = '';
                questions.forEach((q, i) => {
                    const ansLetter = String.fromCharCode(97 + q.ans);
                    container.innerHTML += `
                        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200">
                            <p class="font-extrabold text-indigo-600 mb-2 uppercase text-[11px] tracking-wider border-b border-slate-100 pb-2 flex justify-between font-sans">
                                <span>Subiectul ${i + 1}</span>
                                <span class="text-emerald-500">Răspuns corect: ${ansLetter}</span>
                            </p>
                            <div class="text-slate-700 text-[15px] font-medium leading-relaxed math-text">${q.just}</div>
                        </div>
                    `;
                });
                container.classList.remove('d-none');
                btn.innerHTML = '<i class="fa-solid fa-eye-slash"></i> ASCUNDE BAREMUL';
                
                if (window.MathJax && window.MathJax.typesetPromise) {
                    window.MathJax.typesetPromise([container]);
                }
            } else {
                container.classList.add('d-none');
                btn.innerHTML = '<i class="fa-solid fa-eye"></i> VIZUALIZEAZĂ BAREMUL';
            }
        }

        async function exportToJPG() {
            if (!window.html2canvas) {
                alert('Modulul de export se încarcă, vă rugăm să așteptați 2 secunde și să reîncercați.');
                return;
            }

            const btn = document.getElementById('btn-export');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> <span>Se generează...</span>';
            btn.classList.add('opacity-80', 'cursor-wait');
            
            try {
                const exportElement = document.getElementById('export-template');
                exportElement.style.display = 'block';
                
                const canvas = await html2canvas(exportElement, {
                    scale: 2,
                    backgroundColor: '#0f172a',
                    logging: false
                });
                
                exportElement.style.display = 'none';
                
                const link = document.createElement('a');
                link.download = `Rezultat_Mate_${userName.replace(/\s+/g, '_')}.jpg`;
                link.href = canvas.toDataURL('image/jpeg', 0.95);
                link.click();
            } catch (error) {
                console.error('Export failed:', error);
                alert('Eroare la generarea JPG-ului.');
            } finally {
                btn.innerHTML = '<i class="fa-solid fa-image"></i> <span>Exportă Rezultatul (JPG)</span>';
                btn.classList.remove('opacity-80', 'cursor-wait');
            }
        }

        function restartApp() {
            elUserName.value = '';
            elSelectedVariant.value = '';
            userName = '';
            selectedVariant = '';
            elErrorBox.classList.add('d-none');
            dismissSecurity();
            document.getElementById('barem-container').classList.add('d-none');
            document.getElementById('btn-toggle-barem').innerHTML = '<i class="fa-solid fa-eye"></i> VIZUALIZEAZĂ BAREMUL';
            switchScreen('intro');
        }
    </script>
</body>
</html>
