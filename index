                { q: "Efectuaţi calculul cu radicali: $\\sqrt{45}+2\\sqrt{20}-\\sqrt{80}$", opts: ["$\\sqrt{5}$", "$2\\sqrt{5}$", "$3\\sqrt{5}$", "$4\\sqrt{5}$"], ans: 2, just: "$\\sqrt{45}=3\\sqrt{5}$; $\\sqrt{20}=2\\sqrt{5}$; $\\sqrt{80}=4\\sqrt{5}$. Calcul: $3\\sqrt{5} + 2(2\\sqrt{5}) - 4\\sqrt{5} = 3\\sqrt{5} + 4\\sqrt{5} - 4\\sqrt{5} = 3\\sqrt{5}$." },
                { q: "Calculaţi valoarea expresiei: $\\sqrt[3]{-1000}+\\sqrt[4]{16}$", opts: ["-8", "-12", "12", "8"], ans: 0, just: "$\\sqrt[3]{-1000} = -10$, iar $\\sqrt[4]{16} = 2$. Rezultat: $-10 + 2 = -8$." },
                { q: "Domeniul maxim de existență pentru radicalul $\\sqrt{7x-21}$ este:", opts: ["$[3,\\infty)$", "$(3,\\infty)$", "$(-\\infty,3)$", "$\\mathbb{R}$"], ans: 0, just: "Condiție: $7x - 21 \\ge 0 \\implies 7x \\ge 21 \\implies x \\ge 3$. Domeniul este $[3, \\infty)$." },
                { q: "Domeniul maxim de existență pentru logaritmul $\\log_{5}(x^{2}-4x+3)$ este:", opts: ["$(-\\infty,1)\\cup(3,\\infty)$", "$[1,3]$", "$(1,3)$", "$\\mathbb{R}\\setminus\\{1,3\\}$"], ans: 0, just: "Condiție: $x^2 - 4x + 3 > 0$. Rădăcinile sunt $x_1=1, x_2=3$. Fiind o ecuație de gradul 2, semnul e pozitiv în exteriorul rădăcinilor: $(-\\infty, 1) \\cup (3, \\infty)$." },
                { q: "Utilizând proprietățile operațiilor cu logaritmi, calculați: $A=\\log_{2}40-\\log_{2}5$", opts: ["1", "2", "3", "8"], ans: 2, just: "Avem $\\log_{2}\\left(\\frac{40}{5}\\right) = \\log_{2}8 = \\log_{2}(2^3) = 3$." },
                { q: "Calculați: $P=\\log_{2}5\\cdot \\log_{5}7\\cdot \\log_{7}16$", opts: ["2", "3", "4", "16"], ans: 2, just: "Aplicând schimbarea de bază, se reduc bazele intermediare: $\\log_{2}16 = \\log_{2}(2^4) = 4$." },
                { q: "Calculaţi valoarea expresiei mixte: $E=3^{\\log_{3}15}+\\log_{2}(32)-100^{\\lg~2}$", opts: ["15", "16", "20", "24"], ans: 1, just: "Din formula $a^{\\log_a b} = b$, $3^{\\log_3 15} = 15$. $\\log_2 32 = 5$. $100^{\\lg 2} = (10^2)^{\\lg 2} = 10^{2\\lg 2} = 10^{\\lg 4} = 4$. Deci $15 + 5 - 4 = 16$." }
            ],
            2: [
                { q: "Calculați valoarea expresiei cu puteri: $32^{\\frac{2}{5}}\\cdot2^{3}$", opts: ["4", "8", "16", "32"], ans: 3, just: "$32^{2/5} = (2^5)^{2/5} = 2^2 = 4$. Iar $2^3 = 8$. Deci $4 \\cdot 8 = 32$." },
                { q: "Calculaţi: $\\frac{2^{7}\\cdot4^{3}}{8^{4}}$", opts: ["1", "2", "4", "8"], ans: 1, just: "Transformăm totul în baza 2: $\\frac{2^7 \\cdot (2^2)^3}{(2^3)^4} = \\frac{2^7 \\cdot 2^6}{2^{12}} = \\frac{2^{13}}{2^{12}} = 2^1 = 2$." },
                { q: "Efectuaţi calculul cu radicali: $\\sqrt{150}-\\sqrt{24}+\\sqrt{54}$", opts: ["$2\\sqrt{6}$", "$4\\sqrt{6}$", "$6\\sqrt{6}$", "$8\\sqrt{6}$"], ans: 2, just: "$\\sqrt{150}=5\\sqrt{6}$; $\\sqrt{24}=2\\sqrt{6}$; $\\sqrt{54}=3\\sqrt{6}$. Rezultat: $5\\sqrt{6} - 2\\sqrt{6} + 3\\sqrt{6} = 6\\sqrt{6}$." },
                { q: "Calculați valoarea expresiei: $\\sqrt[3]{-216}+\\sqrt[4]{625}$", opts: ["-1", "1", "11", "-11"], ans: 0, just: "$\\sqrt[3]{-216} = -6$. $\\sqrt[4]{625} = 5$. Deci $-6 + 5 = -1$." },
                { q: "Domeniul maxim de existență pentru radicalul $\\sqrt{12-4x}$ este:", opts: ["$(-\\infty,3]$", "$[3,\\infty)$", "$(3,\\infty)$", "$(-\\infty,3)$"], ans: 0, just: "Condiție: $12 - 4x \\ge 0 \\implies 12 \\ge 4x \\implies x \\le 3$. Intervalul este $(-\\infty, 3]$." },
                { q: "Domeniul maxim de existență pentru logaritmul $\\log_{3}(x^{2}-8x+15)$ este:", opts: ["$(-\\infty,3)\\cup(5,\\infty)$", "$(3,5)$", "$[3,5]$", "$\\mathbb{R}$"], ans: 0, just: "Condiție $x^2 - 8x + 15 > 0$. Rădăcinile sunt $x_1=3, x_2=5$. Parabola ia valori pozitive în exterior: $(-\\infty, 3) \\cup (5, \\infty)$." },
                { q: "Utilizând proprietățile operațiilor cu logaritmi, calculați: $A=\\log_{3}54-\\log_{3}2$", opts: ["3", "27", "2", "4"], ans: 0, just: "$A = \\log_{3}\\left(\\frac{54}{2}\\right) = \\log_{3}27 = \\log_{3}(3^3) = 3$." },
                { q: "Calculaţi: $P=\\log_{3}8\\cdot \\log_{4}5\\cdot \\log_{5}9$", opts: ["2", "3", "4", "6"], ans: 1, just: "Aducem la bazele 2 și 3: $\\log_3(2^3) \\cdot \\frac{\\log_3 5}{\\log_3 4} \\cdot \\log_5(3^2) = 3\\log_3 2 \\cdot \\frac{1}{2\\log_3 2} \\cdot 2 = 3$." },
                { q: "Calculaţi valoarea expresiei mixte: $E=5^{\\log_{5}12}+\\log_{4}(64)-10^{2~\\lg~3}$", opts: ["3", "6", "9", "12"], ans: 1, just: "$5^{\\log_5 12} = 12$. $\\log_4 64 = 3$. $10^{2\\lg 3} = 10^{\\lg 9} = 9$. Rezultat: $12 + 3 - 9 = 6$." }
            ],
            3: [
